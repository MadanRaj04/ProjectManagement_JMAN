generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ManagerWhitelist {
  id           String  @id @default(uuid())
  email        String  @unique
  isRegistered Boolean @default(false)
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  email      String   @unique
  password   String
  role       Role
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  managedProjects Project[]       @relation("ManagerProjects")
  projectMembers  ProjectMember[]

  sentInvites     ProjectInvite[] @relation("ManagerInvites")
  receivedInvites ProjectInvite[] @relation("UserInvites")

  tasks Task[]

  taskComments TaskComment[]
}

model Project {
  id        String @id @default(uuid())
  name      String
  status    String @default("ACTIVE")

  manager   User   @relation("ManagerProjects", fields: [managerId], references: [id])
  managerId String

  members   ProjectMember[]
  invites   ProjectInvite[]

  tasks     Task[]
}

model ProjectMember {
  id        String  @id @default(uuid())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  user      User    @relation(fields: [userId], references: [id])
  userId    String

  @@unique([projectId, userId])
}

model ProjectInvite {
  id        String  @id @default(uuid())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  manager   User    @relation("ManagerInvites", fields: [managerId], references: [id])
  managerId String

  user      User    @relation("UserInvites", fields: [userId], references: [id])
  userId    String

  status    String  @default("PENDING")
}
model JoinRequest {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  status    String  @default("PENDING")
}

enum Role {
  MANAGER
  USER
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  priority    Int        @default(2)  
  status      TaskStatus @default(TODO)

  project     Project    @relation(fields: [projectId], references: [id])
  projectId   String

  assignedTo   User?   @relation(fields: [assignedToId], references: [id])
  assignedToId String?

  comments  TaskComment[]
  createdAt DateTime @default(now())
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}
model TaskComment {
  id        String   @id @default(uuid())
  content   String

  task      Task     @relation(fields: [taskId], references: [id])
  taskId    String

  user      User     @relation(fields: [userId], references: [id])
  userId    String

  createdAt DateTime @default(now())
}